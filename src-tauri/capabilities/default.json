{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the single fullscreen desktop window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-primary-monitor",
    "core:window:allow-show",
    "opener:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "sqlite3", "cmd": "sqlite3", "args": true },
        { "name": "open", "cmd": "open", "args": true },
        {
          "name": "code",
          "cmd": "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code",
          "args": true
        },
        { "name": "github", "cmd": "/usr/local/bin/github", "args": true }
      ]
    }
  ]
}