{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability shared by the bootstrap window and every screen window (matched by glob, so monitor count needs no edit here)",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-available-monitors",
    "core:window:allow-show",
    "opener:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "sqlite3", "cmd": "sqlite3", "args": true }
      ]
    }
  ]
}