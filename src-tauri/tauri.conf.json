{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wigl",
  "version": "0.1.0",
  "identifier": "com.wigl.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "wigl",
        "width": 270,
        "height": 400,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnBottom": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
